# Byte-compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Data files
data/raw/*
data/processed/*
data/synthetic/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/synthetic/.gitkeep

# Reports and generated figures
reports/figures/*
!reports/figures/.gitkeep

# Model artifacts
/models/
*.pkl
*.pickle
*.joblib
*.onnx

# Logs
logs/
*.log

# Test and coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Operating system files
.DS_Store
Thumbs.db

# IDE settings
.idea/
.vscode/
